<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutCrearTorneo"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <!-- Título -->
    <TextView
        android:id="@+id/tvCrearTorneoTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crear Torneo"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#222"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- Nombre -->
    <EditText
        android:id="@+id/inputTorneoNombre"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Nombre del torneo"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvCrearTorneoTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="25dp"/>

    <!-- Fecha -->
    <EditText
        android:id="@+id/inputTorneoFecha"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Fecha (ej: 20/04/2026)"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/inputTorneoNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <!-- Lugar -->
    <EditText
        android:id="@+id/inputTorneoLugar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Lugar"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/inputTorneoFecha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <!-- Estado -->
    <EditText
        android:id="@+id/inputTorneoEstado"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Estado (Abierto, Cerrado...)"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/inputTorneoLugar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <!-- Botón -->
    <Button
        android:id="@+id/btnCrearTorneo"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Crear Torneo"
        android:backgroundTint="#6200EE"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/inputTorneoEstado"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="25dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>