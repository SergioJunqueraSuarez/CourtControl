<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cc_bg">

    <LinearLayout
        android:id="@+id/headerPerfil"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:background="@color/cc_primary"
        android:gravity="bottom|start"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil de usuario"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivPerfilUsuario"
        android:layout_width="108dp"
        android:layout_height="108dp"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:src="@drawable/ic_persona"
        app:layout_constraintTop_toBottomOf="@id/headerPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-28dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        app:cardBackgroundColor="@color/cc_surface"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/cc_border"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/ivPerfilUsuario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/tvNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="@color/cc_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvPasswordUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/cc_success_bg"
                android:padding="12dp"
                android:text="Contrasena: ******"
                android:textColor="@color/cc_success_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnTogglePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mostrar contrasena"
                android:textAllCaps="false"
                android:backgroundTint="@color/cc_primary"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etPasswordNueva"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="@color/cc_primary"
                android:hint="Nueva contrasena"
                android:inputType="textPassword"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/cc_text_primary"
                android:textColorHint="@color/cc_text_secondary"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etPasswordConfirmar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="@color/cc_primary"
                android:hint="Confirmar contrasena"
                android:inputType="textPassword"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/cc_text_primary"
                android:textColorHint="@color/cc_text_secondary"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnGuardarPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/cc_primary_dark"
                android:text="Guardar contrasena"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
