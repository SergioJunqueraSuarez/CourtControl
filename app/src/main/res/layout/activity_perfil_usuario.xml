<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Imagen -->
    <ImageView
        android:id="@+id/ivPerfilUsuario"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_persona"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/ivPerfilUsuario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Nombre -->
            <TextView
                android:id="@+id/tvNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="22sp"
                android:textColor="#333"
                android:layout_marginBottom="16dp"/>

            <!-- Password -->
            <TextView
                android:id="@+id/tvPasswordUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contraseña: ******"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <!-- Toggle -->
            <Button
                android:id="@+id/btnTogglePassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mostrar contraseña"
                android:layout_marginBottom="16dp"/>

            <!-- Nueva contraseña -->
            <EditText
                android:id="@+id/etPasswordNueva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nueva contraseña"
                android:inputType="textPassword"
                android:layout_marginBottom="12dp"/>

            <!-- Confirmar contraseña -->
            <EditText
                android:id="@+id/etPasswordConfirmar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirmar contraseña"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp"/>

            <!-- Guardar -->
            <Button
                android:id="@+id/btnGuardarPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar contraseña"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>