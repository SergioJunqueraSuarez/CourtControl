<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNombreTorneo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Torneo"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvFechaLugar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha - Lugar"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:textColor="@android:color/holo_green_dark"/>

        <!-- 🔥 NUEVO: número de jugadores -->
        <TextView
            android:id="@+id/tvJugadores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/20 jugadores"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:textColor="@android:color/holo_blue_dark"/>

        <TextView
            android:id="@+id/tvCapitanes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Capitanes: 0/4 - faltan 4"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/holo_orange_dark"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
